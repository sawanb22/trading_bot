# Binance Futures TESTNET Credentials — Template
# Copy this file to .env and fill in your actual keys.
# Keys are generated at: https://testnet.binancefuture.com
#
# ⚠️  NEVER put real Mainnet keys here.
# ⚠️  The .env file itself is git-ignored — this template is safe to commit.

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
